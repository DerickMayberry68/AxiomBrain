# AxiomBrain Configuration
# Copy this file to .env and fill in your values

# PostgreSQL / Supabase
DATABASE_URL=postgresql://user:password@localhost:5432/axiombrain
# Or for Supabase:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# API Security
API_KEY=your-secret-api-key-here

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-...

# Notifications — Microsoft Teams
# Paste your Teams channel Incoming Webhook URL here to receive nightly summary notifications.
# In Teams: Channel → ... → Connectors → Incoming Webhook → Configure → copy URL
# Leave blank (or omit) to disable Teams notifications.
# TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/...

# Server
HOST=0.0.0.0
PORT=8000
